FROM python:3.11-slim

WORKDIR /app

# Install system dependencies for jobspy (playwright, browsers, etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    wget \
    ca-certificates \
    gnupg \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libdbus-1-3 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    && rm -rf /var/lib/apt/lists/*

# Install Playwright dependencies
RUN pip install playwright && playwright install chromium

# Copy pyproject.toml and install dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir python-jobspy pandas python-dateutil && \
    pip install --no-cache-dir -e . --ignore-installed

# Copy all backend code to /app (not /app/backend)
COPY . /app/

# Expose port
EXPOSE 8005

# Run the MCP server
CMD ["python", "fastmcp_server.py"]
