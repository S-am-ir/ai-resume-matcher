# --- DATABASE (Local Docker) ---
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
SUPABASE_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# --- AI API KEYS ---
# Get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Get from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: Get from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- GMAIL IMAP (Truly Free Tracking) ---
# 1. Go to your Google Account Security: https://myaccount.google.com/security
# 2. Enable "2-Step Verification".
# 3. Search for "App Passwords" in the search bar.
# 4. Create a new App Password (select "Other" and name it "Anti-Berojgar").
# 5. Paste the 16-character code below.
# NO CREDIT CARD OR GOOGLE CLOUD PROJECT NEEDED!
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16char_app_password_here

# --- MCP CONFIG ---
# This matches the docker-compose.yml configuration
MCP_JOBS_HOST=127.0.0.1
MCP_JOBS_PORT=8005

# --- SUPABASE (Optional/Remote) ---
# Only needed if you are NOT using the local Docker DB
SUPABASE_URL=
SUPABASE_KEY=
