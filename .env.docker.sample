# Backend Environment Variables
# Copy this file to .env.docker and fill in your actual values

# Database (Docker)
DATABASE_URL=postgresql://antiberojgar:password@db:5432/antiberojgar
SUPABASE_DB_URL=postgresql://antiberojgar:password@db:5432/antiberojgar

# MCP Jobs Service (Docker)
MCP_JOBS_HOST=mcp_jobs
MCP_JOBS_PORT=8005

# API Keys (Get your own free keys)
# Groq API: https://console.groq.com/keys (free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API: https://makersuite.google.com/app/apikey (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API (optional): https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
